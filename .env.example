# ==============================================
# 不过期助手 MCP Server 环境变量配置示例
# ==============================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填写你的实际配置
# 3. 不要将 .env 文件提交到代码仓库！

# ----------------------------------------------
# API 配置（必填）
# ----------------------------------------------
# 后端 API 服务地址
BAOZHIBAO_API_URL=https://h1b.site/out_date

# ----------------------------------------------
# 认证配置（可选）
# ----------------------------------------------
# API Key，用于默认登录
# 获取方式：打开小程序 -> 设置 -> API Key 管理 -> 创建 API Key
# 留空则需要在客户端手动调用 login 工具
BAOZHIBAO_API_KEY=sk_your_api_key_here

# ----------------------------------------------
# 开发配置（可选）
# ----------------------------------------------
# 是否启用调试日志
DEBUG=false

# MCP 服务日志级别（error, warn, info, debug）
LOG_LEVEL=info
